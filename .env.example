# =============================================================================
# incident-sense — example environment file
# -----------------------------------------------------------------------------
# Copy this file to ".env" and fill in your own keys:
#     cp .env.example .env
# The real ".env" is gitignored and must NEVER be committed.
# Values below are fictional placeholders for a demo of the fictional
# "Banco Meridiano". They are NOT anyone's production values.
# =============================================================================

# --- LLM / embedding providers -----------------------------------------------
# Embeddings run on OpenAI (text-embedding-3-large, 3072 dimensions).
OPENAI_API_KEY=sk-your-openai-key-here

# Chat / reasoning and cluster labeling run on OpenRouter (OpenAI-compatible).
OPENROUTER_API_KEY=sk-or-your-openrouter-key-here

# Chat model used for summarization, post-filter, classification and labels.
# Configurable on purpose. Fallback example: openai/gpt-5.4-mini
LLM_MODEL=deepseek/deepseek-v4-flash

# Embedding model. Vector size MUST stay 3072 (Qdrant collection is sized to it).
EMBEDDING_MODEL=text-embedding-3-large

# --- Vector database ---------------------------------------------------------
# Local Qdrant. In docker compose this is overridden to http://qdrant:6333.
QDRANT_URL=http://localhost:6333

# --- Frontend ----------------------------------------------------------------
# Public base URL the browser uses to reach the backend API.
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Backend tuning (illustrative example values, not production tuning) ------
LOG_LEVEL=INFO
# CORS: the local frontend origin allowed to call the API.
FRONTEND_ORIGIN=http://localhost:3000
